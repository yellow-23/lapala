# Supabase — get from supabase.com/dashboard > Settings > API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend / scrapers (not exposed to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Postgres direct connection — for SQLAlchemy / Alembic
# Get from supabase.com/dashboard > Settings > Database > Connection string (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres

# Optional: only if you self-host the FastAPI backend
API_URL=http://localhost:8000
