---
import Layout from "../layouts/Layout.astro";
import AIPanel from "../features/ai/AIPanel.tsx";
---

<Layout title="IA — LaPala">
  <nav class="fixed top-0 inset-x-0 z-50 border-b border-white/8 bg-[#0a0a0f]/80 backdrop-blur-sm">
    <div class="max-w-2xl mx-auto px-4 h-13 flex items-center justify-between">
      <a href="/" class="font-bold text-white tracking-tight text-sm hover:text-blue-600 transition-colors">
        LaPala
      </a>
      <div class="flex items-center gap-2">
        <a href="/cv" class="text-xs px-3 py-1.5 rounded-full border border-white/15 text-gray-300 hover:border-blue-600/40 hover:text-blue-400 transition-colors">
          Armar CV
        </a>
        <a href="/" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">
          Ver pegas →
        </a>
      </div>
    </div>
  </nav>

  <div class="max-w-2xl mx-auto px-4 pt-24 pb-24">
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center gap-1.5 text-xs text-blue-600 border border-blue-700/30 rounded-full px-3 py-1 bg-blue-700/10">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 1L6.2 3.8L9 4L6.8 6.1L7.4 9L5 7.6L2.6 9L3.2 6.1L1 4L3.8 3.8L5 1Z" fill="currentColor"/>
          </svg>
          Potenciado por Claude
        </span>
      </div>
      <h1 class="text-2xl font-bold tracking-tight mb-2">
        IA para tu <span class="text-blue-600">postulacion</span>
      </h1>
      <p class="text-sm text-gray-500">Genera tu CV desde texto libre o analiza tu compatibilidad con una oferta. Gratis, sin cuenta.</p>
    </div>

    <AIPanel client:load />
  </div>
</Layout>
