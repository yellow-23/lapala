---
import Layout from "../layouts/Layout.astro";
import { CVBuilder } from "../features/cv";
---

<Layout title="Armar CV — LaPala">
  <nav class="fixed top-0 inset-x-0 z-50 border-b border-white/8 bg-[#0a0a0f]/80 backdrop-blur-sm">
    <div class="max-w-2xl mx-auto px-4 h-13 flex items-center justify-between">
      <a href="/" class="font-bold text-white tracking-tight text-sm hover:text-blue-600 transition-colors">
        LaPala
      </a>
      <a href="/" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">
        ← Ver pegas
      </a>
    </div>
  </nav>

  <div class="max-w-2xl mx-auto px-4 pt-24 pb-24">
    <div class="mb-10">
      <h1 class="text-2xl font-bold tracking-tight mb-2">
        Arma tu <span class="text-blue-600">CV</span>
      </h1>
      <p class="text-sm text-gray-500">Formulario guiado → PDF descargable · gratis · sin cuenta</p>
    </div>

    <CVBuilder client:load />
  </div>
</Layout>
