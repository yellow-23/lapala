---
import Layout from "../layouts/Layout.astro";
import JobList from "../features/jobs/JobList.tsx";
---

<Layout title="LaPala — Encuentra tu pega en Chile">
  <!-- Navbar -->
  <nav class="fixed top-0 inset-x-0 z-50 border-b border-white/8 bg-[#0a0a0f]/80 backdrop-blur-sm">
    <div class="max-w-3xl mx-auto px-4 h-13 flex items-center justify-between">
      <span class="font-bold text-white tracking-tight text-sm">LaPala</span>
      <div class="flex items-center gap-2">
        <a href="https://github.com/yellow-23/lapala" target="_blank" rel="noopener noreferrer"
          class="text-gray-600 hover:text-gray-300 transition-colors" aria-label="Repositorio en GitHub">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a href="/cv" class="text-xs px-3 py-1.5 rounded-full border border-white/15 text-gray-300 hover:border-blue-600/40 hover:text-blue-400 transition-colors">
          Armar CV
        </a>
        <a href="/ai" class="text-xs px-3 py-1.5 rounded-full bg-blue-800 hover:bg-blue-700 text-white font-medium transition-colors flex items-center gap-1.5">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <path d="M5 1L6.2 3.8L9 4L6.8 6.1L7.4 9L5 7.6L2.6 9L3.2 6.1L1 4L3.8 3.8L5 1Z" fill="currentColor"/>
          </svg>
          IA
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <div class="relative overflow-hidden pt-13">
    <!-- Dot grid bg -->
    <div
      class="pointer-events-none absolute inset-0 opacity-20"
      style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    ></div>

    <!-- Gradient blobs -->
    <div
      class="pointer-events-none absolute top-[-20rem] right-[-12rem] flex gap-[5rem] opacity-30"
      style="transform: rotate(-20deg) skewX(-40deg); filter: blur(4rem);"
    >
      <div class="w-32 h-72 bg-gradient-to-b from-white to-blue-300"></div>
      <div class="w-32 h-72 bg-gradient-to-b from-white to-blue-400"></div>
      <div class="w-32 h-72 bg-gradient-to-b from-white to-blue-300"></div>
    </div>
    <div
      class="pointer-events-none absolute top-[-28rem] right-[-24rem] flex gap-[5rem] opacity-20"
      style="transform: rotate(-20deg) skewX(-40deg); filter: blur(4rem);"
    >
      <div class="w-32 h-96 bg-gradient-to-b from-white to-blue-300"></div>
      <div class="w-32 h-96 bg-gradient-to-b from-white to-blue-300"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto px-4 pt-16 pb-10 text-center">
      <!-- Status pill -->
      <span
        class="inline-flex items-center gap-2 text-xs text-gray-400 border border-white/10 rounded-full px-4 py-1.5 mb-8 bg-white/5"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        Actualizado cada 6h · gratis · open source
      </span>

      <!-- Title -->
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight leading-none mb-5">
        Encuentra tu<br />
        <span class="text-blue-600">pega</span> <span class="text-white">en</span> <span class="text-[#da291c]">Chile</span>
      </h1>

      <p class="text-gray-500 text-base">
        Tech, ventas, salud, construcción y más — actualizado cada 6h
      </p>
    </div>
  </div>

  <!-- Interactive job list (React island) -->
  <div class="max-w-3xl mx-auto px-4 pb-24">
    <JobList client:load />
  </div>
</Layout>
